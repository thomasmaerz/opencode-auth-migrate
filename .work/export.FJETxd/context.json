{
  "plugins": [
    {
      "kind": "package",
      "source_spec": "opencode-antigravity-auth@latest"
    },
    {
      "kind": "package",
      "source_spec": "superpowers@git+https://github.com/obra/superpowers.git"
    },
    {
      "kind": "package",
      "source_spec": "@guard22/opencode-multi-auth-codex@latest"
    }
  ],
  "providers_from_auth": [
    "google",
    "openrouter",
    "qwen-code",
    "qwen",
    "qwen-code-oauth",
    "openai",
    "nvidia",
    "kilo"
  ],
  "providers_from_config": [
    "google",
    "nvidia"
  ],
  "provider_models": {
    "google": [
      "antigravity-gemini-3-pro",
      "antigravity-gemini-3.1-pro",
      "antigravity-gemini-3-flash",
      "antigravity-claude-sonnet-4-6",
      "antigravity-claude-opus-4-6-thinking",
      "gemini-2.5-flash",
      "gemini-2.5-pro",
      "gemini-3-flash-preview",
      "gemini-3-pro-preview",
      "gemini-3.1-pro-preview",
      "gemini-3.1-pro-preview-customtools"
    ],
    "nvidia": [
      "minimaxai/minimax-m2.7"
    ]
  },
  "config_files": [
    "~/.config/opencode/opencode.json",
    "~/.config/opencode/config.json"
  ],
  "auth_file": "~/.local/share/opencode/auth.json",
  "config_dir": "~/.config/opencode"
}